{
  "scenarios": [
    {
      "keywords": ["端口", "占用", "port", "8080", "监听", "listen"],
      "title": "查看端口被谁占用",
      "primary": {"cmd": "ss -lntp | grep ':8080'", "needs": ["ss"]},
      "fallback": {"cmd": "sudo lsof -i :8080", "needs": ["lsof"]},
      "explain": [
        "ss   查看网络连接",
        "-l   只看监听端口",
        "-n   显示数字端口，不解析域名",
        "-t   只看 TCP",
        "-p   显示占用进程（看不到进程名时加 sudo）"
      ],
      "risk": 0,
      "note": "把 :8080 换成你关心的端口。只读查询，不会修改系统。"
    },
    {
      "keywords": ["大文件", "大于", "占空间", "large file", "size"],
      "title": "查找大文件",
      "primary": {"cmd": "find . -type f -size +100M", "needs": ["find"]},
      "fallback": {"cmd": "du -ah . 2>/dev/null | sort -h | tail -n 20", "needs": ["du"]},
      "explain": [
        "find .        从当前目录开始查找",
        "-type f       只查普通文件",
        "-size +100M   文件大小大于 100MB"
      ],
      "risk": 0,
      "note": "想看详细大小：find . -type f -size +100M -exec ls -lh {} \\;"
    },
    {
      "keywords": ["磁盘", "满了", "空间", "disk", "df", "du"],
      "title": "查看磁盘空间 / 哪个目录最大",
      "primary": {"cmd": "df -h", "needs": ["df"]},
      "fallback": {"cmd": "du -h --max-depth=1 . 2>/dev/null | sort -h", "needs": ["du"]},
      "explain": [
        "df -h               查看各分区使用情况（人类可读单位）",
        "du -h --max-depth=1 查看当前目录下各子目录大小"
      ],
      "risk": 0,
      "note": "不要直接 rm -rf /var/*，先确认大文件来源再清理。"
    },
    {
      "keywords": ["递归", "搜索", "文本", "error", "日志", "grep", "查找内容", "关键词"],
      "title": "在文件/目录里搜索文本",
      "primary": {"cmd": "grep -rn \"error\" .", "needs": ["grep"]},
      "fallback": {"cmd": "grep -rin \"error\" .", "needs": ["grep"]},
      "explain": [
        "grep   搜索文本",
        "-r     递归搜索目录",
        "-n     显示行号",
        "-i     可选：忽略大小写"
      ],
      "risk": 0,
      "note": "把 error 换成你要找的关键词。grep 默认不递归，目录搜索一定要加 -r。"
    },
    {
      "keywords": ["打包", "压缩", "tar.gz", "tar", "归档", "archive"],
      "title": "把目录打包成 tar.gz",
      "primary": {"cmd": "tar -czf backup.tar.gz ./dir", "needs": ["tar"]},
      "fallback": {"cmd": "tar -czvf backup.tar.gz ./dir", "needs": ["tar"]},
      "explain": [
        "-c   创建压缩包",
        "-z   用 gzip 压缩",
        "-f   指定输出文件名",
        "-v   可选：显示过程"
      ],
      "risk": 1,
      "note": "解压则用 tar -xzf backup.tar.gz。"
    },
    {
      "keywords": ["解压", "解包", "extract", "unzip", "tar.gz"],
      "title": "解压压缩包",
      "primary": {"cmd": "tar -xzf file.tar.gz", "needs": ["tar"]},
      "fallback": {"cmd": "unzip file.zip", "needs": ["unzip"]},
      "explain": [
        ".tar.gz  用 tar -xzf",
        ".tar.xz  用 tar -xJf",
        ".zip     用 unzip"
      ],
      "risk": 1,
      "note": "不确定包里有什么，先 tar -tzf file.tar.gz 看一眼。"
    },
    {
      "keywords": ["服务", "启动", "nginx", "systemctl", "running", "状态"],
      "title": "查看服务是否启动 / 状态",
      "primary": {"cmd": "systemctl status nginx", "needs": ["systemctl"]},
      "fallback": {"cmd": "ps aux | grep nginx", "needs": ["ps"]},
      "explain": [
        "systemctl status <服务名>  查看服务状态（只读，通常不用 sudo）"
      ],
      "risk": 0,
      "note": "把 nginx 换成你的服务名。启动失败看日志：journalctl -u nginx -n 100"
    },
    {
      "keywords": ["失败", "启动失败", "为什么", "日志", "journalctl", "排查"],
      "title": "查看服务为什么启动失败",
      "primary": {"cmd": "journalctl -u nginx -n 100 --no-pager", "needs": ["journalctl"]},
      "fallback": {"cmd": "systemctl status nginx", "needs": ["systemctl"]},
      "explain": [
        "journalctl  查看 systemd 日志",
        "-u nginx    只看 nginx 服务",
        "-n 100      最近 100 行",
        "--no-pager  直接输出不分页"
      ],
      "risk": 0,
      "note": "先 systemctl status 看概况，再用 journalctl 看详细报错。"
    },
    {
      "keywords": ["进程", "process", "查进程", "node", "运行"],
      "title": "查看某个进程是否在运行",
      "primary": {"cmd": "ps aux | grep node", "needs": ["ps"]},
      "fallback": {"cmd": "pgrep -a node", "needs": ["pgrep"]},
      "explain": [
        "ps aux         列出所有进程",
        "| grep node    过滤出 node 相关"
      ],
      "risk": 0,
      "note": "把 node 换成你关心的进程名。grep 自己也会出现在结果里，属正常。"
    },
    {
      "keywords": ["执行权限", "可执行", "chmod", "脚本", "executable", "+x"],
      "title": "给脚本添加执行权限",
      "primary": {"cmd": "chmod +x script.sh", "needs": ["chmod"]},
      "fallback": {"cmd": "bash script.sh", "needs": ["bash"]},
      "explain": [
        "chmod +x   给文件加上可执行权限"
      ],
      "risk": 1,
      "note": "只需 +x 即可，不要用 chmod 777。也可以直接 bash script.sh 运行而不加权限。"
    },
    {
      "keywords": ["最近修改", "最新", "recent", "modified", "mtime"],
      "title": "查找最近修改的文件",
      "primary": {"cmd": "find . -type f -mtime -1", "needs": ["find"]},
      "fallback": {"cmd": "ls -lt | head", "needs": ["ls"]},
      "explain": [
        "find .       从当前目录查找",
        "-type f      只看普通文件",
        "-mtime -1    最近 1 天内修改过"
      ],
      "risk": 0,
      "note": "当前目录直接看最新：ls -lt | head"
    },
    {
      "keywords": ["下载", "download", "wget", "curl", "文件"],
      "title": "下载文件",
      "primary": {"cmd": "curl -fsSLO https://example.com/file", "needs": ["curl"]},
      "fallback": {"cmd": "wget https://example.com/file", "needs": ["wget"]},
      "explain": [
        "curl -O   下载并保留远程文件名",
        "-f        失败时返回错误",
        "-L        跟随重定向"
      ],
      "risk": 1,
      "note": "不要 curl ... | bash 直接执行远程脚本，先下载用 less 看内容再运行。"
    }
  ]
}
