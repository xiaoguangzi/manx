{
  "command": "ps",
  "purpose": "查看当前运行的进程",
  "common_tasks": [
    {
      "cmd": "ps aux",
      "desc": "查看所有进程（最常用）"
    },
    {
      "cmd": "ps aux | grep nginx",
      "desc": "查找 nginx 相关进程"
    },
    {
      "cmd": "ps -ef",
      "desc": "另一种常见的全进程格式"
    }
  ],
  "common_options": [
    {
      "option": "a",
      "meaning": "显示所有用户的进程"
    },
    {
      "option": "u",
      "meaning": "显示进程归属用户和资源占用"
    },
    {
      "option": "x",
      "meaning": "包含没有控制终端的进程（如后台服务）"
    },
    {
      "option": "-e",
      "meaning": "显示所有进程"
    },
    {
      "option": "-f",
      "meaning": "完整格式输出"
    }
  ],
  "common_mistakes": [
    "ps 是某一时刻的快照，要持续观察用 top / htop"
  ],
  "risks": [
    "ps 是只读命令，无风险"
  ],
  "next_steps": [
    "拿到 PID 后，可用 kill <PID> 结束进程（先确认是什么进程）"
  ]
}
