{
  "command": "grep",
  "purpose": "从文本里搜索匹配的内容（按行匹配，支持正则）",
  "common_tasks": [
    {
      "cmd": "grep \"error\" app.log",
      "desc": "在 app.log 里找包含 error 的行"
    },
    {
      "cmd": "grep -r \"error\" .",
      "desc": "递归搜索当前目录下所有文件"
    },
    {
      "cmd": "grep -i \"error\" app.log",
      "desc": "忽略大小写"
    },
    {
      "cmd": "grep -n \"error\" app.log",
      "desc": "显示匹配所在行号"
    },
    {
      "cmd": "grep -v \"debug\" app.log",
      "desc": "反向匹配：排除含 debug 的行"
    }
  ],
  "common_options": [
    {
      "option": "-r, --recursive",
      "meaning": "递归搜索目录下所有文件"
    },
    {
      "option": "-i, --ignore-case",
      "meaning": "忽略大小写"
    },
    {
      "option": "-n, --line-number",
      "meaning": "显示行号"
    },
    {
      "option": "-v, --invert-match",
      "meaning": "反向匹配，只显示不含关键词的行"
    },
    {
      "option": "-E, --extended-regexp",
      "meaning": "使用扩展正则（支持 + ? | 等）"
    },
    {
      "option": "-c, --count",
      "meaning": "只输出匹配的行数"
    },
    {
      "option": "-l, --files-with-matches",
      "meaning": "只列出含匹配的文件名"
    }
  ],
  "common_mistakes": [
    "grep 默认不递归目录，搜索整个目录要加 -r",
    "正则里的特殊字符（. * [ ]）需要转义或用 -F 按字面匹配"
  ],
  "risks": [
    "grep 本身是只读、低风险命令"
  ],
  "next_steps": [
    "grep -rn \"关键词\" . 是日志排查里最常用的组合"
  ]
}
