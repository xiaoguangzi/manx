{
  "command": "tar",
  "purpose": "打包和解包文件（常配合 gzip/xz 压缩）",
  "common_tasks": [
    {
      "cmd": "tar -xzf file.tar.gz",
      "desc": "解压 .tar.gz"
    },
    {
      "cmd": "tar -czf backup.tar.gz ./dir",
      "desc": "把 ./dir 打包成 .tar.gz"
    },
    {
      "cmd": "tar -tzf file.tar.gz",
      "desc": "查看压缩包内容（不解压）"
    },
    {
      "cmd": "tar -xzf file.tar.gz -C /tmp",
      "desc": "解压到指定目录 /tmp"
    },
    {
      "cmd": "tar -xJf file.tar.xz",
      "desc": "解压 .tar.xz"
    }
  ],
  "common_options": [
    {
      "option": "-x",
      "meaning": "解包 extract"
    },
    {
      "option": "-c",
      "meaning": "创建压缩包 create"
    },
    {
      "option": "-t",
      "meaning": "列出包内文件 list"
    },
    {
      "option": "-z",
      "meaning": "用 gzip 处理 .gz / .tar.gz"
    },
    {
      "option": "-J",
      "meaning": "用 xz 处理 .tar.xz"
    },
    {
      "option": "-j",
      "meaning": "用 bzip2 处理 .tar.bz2"
    },
    {
      "option": "-f",
      "meaning": "指定文件名，后面紧跟包文件名"
    },
    {
      "option": "-v",
      "meaning": "显示处理过程"
    },
    {
      "option": "-C",
      "meaning": "指定解压/打包的目标目录"
    }
  ],
  "common_mistakes": [
    "-f 后面要紧跟文件名",
    "-x 是解包、-c 是创建，不要混用（-c 用错会覆盖你的包）",
    ".tar.gz 用 -z，.tar.xz 用 -J，.tar.bz2 用 -j"
  ],
  "risks": [
    "-c 创建时如果目标名写成已有重要文件会被覆盖"
  ],
  "next_steps": [
    "不确定包里有什么，先 tar -tzf 看一眼再解压"
  ]
}
