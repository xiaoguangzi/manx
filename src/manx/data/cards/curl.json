{
  "command": "curl",
  "purpose": "用命令行发起网络请求 / 下载文件",
  "common_tasks": [
    {
      "cmd": "curl -fsSL https://example.com",
      "desc": "安静地获取网页内容"
    },
    {
      "cmd": "curl -O https://example.com/file.tar.gz",
      "desc": "下载文件并保留原名"
    },
    {
      "cmd": "curl -I https://example.com",
      "desc": "只看响应头（检查是否可达）"
    }
  ],
  "common_options": [
    {
      "option": "-O, --remote-name",
      "meaning": "下载并以远程文件名保存"
    },
    {
      "option": "-o",
      "meaning": "下载并保存为指定文件名"
    },
    {
      "option": "-L, --location",
      "meaning": "跟随重定向"
    },
    {
      "option": "-f, --fail",
      "meaning": "HTTP 错误时返回失败而不是输出错误页"
    },
    {
      "option": "-s, --silent",
      "meaning": "安静模式，不显示进度"
    },
    {
      "option": "-I, --head",
      "meaning": "只请求响应头"
    }
  ],
  "common_mistakes": [
    "curl ... | bash 会直接执行远程脚本，先下载用 less 看内容再执行更安全"
  ],
  "risks": [
    "curl 下载本身低风险；但 curl|bash 管道执行远程脚本是高风险"
  ],
  "next_steps": [
    "安装脚本建议：curl -fsSLO URL；less script.sh；确认后 bash script.sh"
  ]
}
